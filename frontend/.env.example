# Supabase (required for production realtime + Postgres)
# Must match backend Supabase project
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps JavaScript API (browser — restrict by HTTP referrer in Google Cloud)
# Option A: set here for Vite dev/build
VITE_GOOGLE_MAPS_API_KEY=
# Option B: set GOOGLE_MAPS_BROWSER_KEY in backend/.env — frontend loads it from /api/location/maps-config

# Optional: override Socket.io URL when not using Supabase (local SQLite dev)
# VITE_SOCKET_URL=http://localhost:3001
