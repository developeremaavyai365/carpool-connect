PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Public URL when deployed or using a tunnel (npm run start:public)
# PUBLIC_URL=https://your-app.trycloudflare.com

# Comma-separated extra allowed origins (optional)
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# Allow any origin — only for local tunnel testing
# CORS_ALLOW_ALL=true

# Trust X-Forwarded-* headers when behind a reverse proxy / tunnel
# TRUST_PROXY=true
# ── Supabase (recommended for production) ──
# When all three are set, the app uses Postgres + Supabase Auth + Realtime.
# Run supabase/migrations/001_initial_schema.sql in your Supabase SQL editor first.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Management API token — enables auto-updating Auth Site URL when Cloudflare tunnel restarts.
# Create at https://supabase.com/dashboard/account/tokens then run:
#   npm run supabase:setup-auto-urls -- sbp_your_token_here
# SUPABASE_ACCESS_TOKEN=sbp_...

# SQLite database file (used when Supabase is not configured)
# DATABASE_PATH=./data/carpool.db

# ── Gmail (notification emails + OTP when Supabase is NOT configured) ──
# When Supabase is active, register/forgot-password OTP codes are sent by Supabase Auth.
# Gmail is still used for welcome emails and carpool notification alerts if configured.
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (no spaces)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Set false in production so OTP codes are never returned in API responses
OTP_DEV_MODE=false

# Optional admin account (NOT the Gmail sender — set only if you need broadcast tools)
# APP_OWNER_EMAIL=admin@yourcompany.com
# APP_OWNER_PASSWORD=
# APP_OWNER_NAME=Administrator

# SMS OTP via Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional geocoding + live driving routes on Publish commute
# Enable in Google Cloud Console for the same project:
#   Maps JavaScript API, Places API, Directions API, Distance Matrix API, Geocoding API
# https://console.cloud.google.com/google/maps-apis
LOCATIONIQ_API_KEY=
# Server-side key (IP-restricted): Places, Directions, Geocoding, Distance Matrix
GOOGLE_MAPS_API_KEY=
# Browser key (HTTP referrer-restricted): Maps JavaScript API — served via /api/location/maps-config
GOOGLE_MAPS_BROWSER_KEY=
# Prefer Google over LocationIQ/ORS when server key is set (default: true when key present)
GOOGLE_MAPS_PREFERRED=true

# ── Geospatial ride matching + real-time publish routes ──
# Required for /api/rides PostGIS sync when using Supabase Postgres
# SUPABASE_DB_PASSWORD=your-db-password

# OpenRouteService — toll routes, alternatives (free: https://openrouteservice.org/dev/#/signup)
OPENROUTESERVICE_API_KEY=
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org

# Geospatial ride matching radius in kilometers (default 50)
MATCHING_RADIUS_KM=50

# OSRM fallback (used automatically when ORS key is empty or ORS fails)
# OSRM_BASE_URL=https://router.project-osrm.org

# REDIS_URL=redis://localhost:6379
